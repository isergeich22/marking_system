{{> sub-nav buttons=buttons}}

<section class="table">
    <div class="marks-table">
        <div class="marks-table-header">
            <div class="header-cell">Номер заказа WB</div>
            <div class="header-cell">Наименование</div>
            <div class="header-cell">Артикул</div>
            <div class="header-cell">КИЗ</div>
        </div>
        <div class="header-wrapper"></div>
        {{#each orders}}
        <div class="table-row">
            <span class="col-order">{{orderNumber}}</span>
            <span class="col-product">{{orderProduct}}</span>
            <span class="col-vendor">{{orderCode}}</span>
            <span class="col-mark">{{mark}}</span>
        </div>
        {{/each}}
    </div>
</section>
<div class="body-wrapper"></div>
