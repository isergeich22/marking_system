{{> sub-nav buttons=buttons}}

<div class="result">Файл {{fileName}} успешно сформирован</div>
<section class="table">
    <div class="marks-table">
        <div class="marks-table-header">
            <div class="header-cell">КИЗ</div>
            <div class="header-cell">Цена</div>
            <div class="header-cell">Тип документа</div>
            <div class="header-cell">Номер документа</div>
            <div class="header-cell">Дата документа</div>
        </div>
        <div class="header-wrapper"></div>
        {{#each rows}}
        <div class="table-row">
            <span class="col-mark">{{mark}}</span>
            <span class="col-gtin">{{price}}</span>
            <span class="col-name">CONSIGNMENT_NOTE</span>
            <span class="col-status">{{consignmentNumber}}</span>
            <span class="col-date">{{consignmentDate}}</span>
        </div>
        {{/each}}
    </div>
</section>
<div class="body-wrapper"></div>
